# ── Pareeksha Gurukul Environment Variables ──────────────────────────────────
# Add these in Railway → your service → Variables tab
# DO NOT commit this file with real values to GitHub

# Your Telegram bot token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# Evaluation group chat ID — negative number e.g. -1001234567890
# 1. Add bot to your group
# 2. Make it an Admin
# 3. Visit https://api.telegram.org/bot<TOKEN>/getUpdates after sending a msg in group
# 4. Find "chat":{"id": <this negative number>}
EVAL_GROUP_ID=-1001234567890

# Your Railway app public URL — NO trailing slash
# Railway gives this after first deploy e.g. https://pg-production.up.railway.app
WEBAPP_URL=https://your-app.up.railway.app

# Comma-separated Telegram user IDs of admins
# To get your ID: message @userinfobot on Telegram
ADMIN_IDS=123456789,987654321

# PORT is set automatically by Railway — do not set this manually
